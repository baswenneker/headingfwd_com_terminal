# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Database Configuration
# For development/test: Use local SQLite
DATABASE_URL="file:./db.sqlite"

# For production: Use Turso (uncomment and configure)
# DATABASE_URL="libsql://your-database-name.turso.io"
# TURSO_AUTH_TOKEN="your-turso-auth-token"

# Optional: Turso auth token for remote database access
# Get this from: turso db tokens create <database-name>
# Leave empty for local SQLite development
TURSO_AUTH_TOKEN=""

# Cloudflare Turnstile (CAPTCHA)
TURNSTILE_SECRET_KEY="your-secret-key"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-site-key"

# Disable CAPTCHA verification (useful for development/test environments)
# Set to "true" to skip Cloudflare Turnstile verification on both client and server
# WARNING: Never set to "true" in production!
NEXT_PUBLIC_DISABLE_CAPTCHA="false"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# Resend (Email API)
# Used for sending contact form emails
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY="your-resend-api-key"

# Rate Limiting
# Maximum number of AI messages per minute (default: 10)
MESSAGE_RATE_LIMIT="10"

# LangSmith (optional)
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY="your-langsmith-api-key"
LANGSMITH_PROJECT="your-project-name"

# Contact Information
# Used by the /contact command to display contact details
CONTACT_EMAIL="your-email@example.com"
CONTACT_LINKEDIN="https://www.linkedin.com/in/yourprofile"
CONTACT_GITHUB="https://github.com/yourusername"

# Example:
# SERVERVAR="foo"
# NEXT_PUBLIC_CLIENTVAR="bar"
