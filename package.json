    "@tanstack/react-query": "^5.90.5",
    "@trpc/client": "^11.7.0",
    "@trpc/react-query": "^11.7.0",
    "@trpc/server": "^11.7.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "ai": "^5.0.81",
    "drizzle-orm": "^0.41.0",
    "langsmith": "^0.3.75",
    "marked": "^16.4.1",
    "next": "16.0.10",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "resend": "^6.4.1",
    "server-only": "^0.0.1",
    "superjson": "^2.2.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.56.1",
