# Test Environment Configuration
# This file is used during Playwright test execution

# Skip environment validation for tests
SKIP_ENV_VALIDATION=1

# Disable CAPTCHA for automated tests
NEXT_PUBLIC_DISABLE_CAPTCHA=true

# Use file-based SQLite database for tests (will be cleaned up after tests)
DATABASE_URL=file:./tmp/db/test.db

# Set to test environment
NODE_ENV=test

# Skip live API tests (set to false to run tests against real OpenAI API)
SKIP_LIVE_TESTS=false

# Test API keys (use real key if SKIP_LIVE_TESTS=false)
# OPENAI_API_KEY=test-key-playwright

# Rate limiting (set to 2 for faster tests)
MESSAGE_RATE_LIMIT=2

# Test Turnstile keys (bypassed when CAPTCHA is disabled)
TURNSTILE_SECRET_KEY=test-turnstile-secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=test-turnstile-site-key
